{
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/*.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/api/extract", "destination": "/api/extract" },
    { "source": "/api/download", "destination": "/api/download" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
