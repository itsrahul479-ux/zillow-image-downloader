{
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/extract",
      "destination": "/api/extract"
    },
    {
      "source": "/api/download",
      "destination": "/api/download"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
